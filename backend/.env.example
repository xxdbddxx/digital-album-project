# Copy this file to .env.local and fill in the real key.
# .env.local is ignored by Git.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=replace_with_your_key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Alibaba Cloud Bailian CosyVoice
TTS_PROVIDER=aliyun
DASHSCOPE_API_KEY=replace_with_your_key
ALIYUN_TTS_MODEL=cosyvoice-v3-flash
ALIYUN_TTS_VOICE=longanhuan_v3
ALIYUN_TTS_VOLUME=60
ALIYUN_TTS_SPEECH_RATE=1.0

# ASR: use GPU large-v3-turbo when CUDA is available, otherwise CPU medium.
WHISPER_MODEL=large-v3-turbo
WHISPER_CPU_FALLBACK_MODEL=medium
WHISPER_BEAM_SIZE=5
WHISPER_CPU_THREADS=4

# Music and TTS default volume.
MUSIC_PLAYBACK_VOLUME=60
